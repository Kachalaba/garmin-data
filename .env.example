# Copy to .env and edit. Scripts do NOT read .env automatically —
# either export manually or use direnv / `set -a; source .env; set +a`.

# Path to the SQLite database. Default: ./health.db
GARMIN_DB_PATH=./health.db

# Path to the sync log file. Default: ./sync.log
GARMIN_LOG_PATH=./sync.log

# user_id used in health tables. Default: 1
GARMIN_USER_ID=1

# Geographic coordinates for weather enrichment (Open-Meteo).
# Default: Kyiv (50.4501, 30.5234). Change to your city.
GARMIN_LAT=50.4501
GARMIN_LON=30.5234
